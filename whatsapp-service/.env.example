# Puerto del servicio
PORT=3100

# URL del backend FastAPI de AgentFlow
AGENTFLOW_API_URL=http://localhost:8200/api

# Secret compartido con el backend (el mismo valor que WHATSAPP_WEBHOOK_API_KEY en backend/.env)
WHATSAPP_WEBHOOK_API_KEY=cambiar-este-valor

# Carpeta donde Baileys guarda la sesion (no commitear, va al .gitignore)
AUTH_FOLDER=./auth_info_baileys
